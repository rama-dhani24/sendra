rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ── Admin panel: full read access to everything ──────────────────────
    match /{document=**} {
      allow read: if true;
    }
    // ── App users ────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /transactions/{txId} {
      allow read: if true;
      allow write, create: if request.auth != null;
    }
    match /notifications/{notifId} {
      allow read: if true;
      allow write, create: if request.auth != null;
    }
    // ── OTPs — writable by anyone, readable by no one ────────────────────
    match /otps/{phone} {
      allow write: if true;
      allow read: if false;
    }
  }
}